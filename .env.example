# ============================================
# BabyBlog — Настройки окружения
# ============================================
# Этот файл готов к использованию.
# Просто скопируйте: cp .env.example .env
# ============================================

# Django
DJANGO_SECRET_KEY=1m7jofvf5p_b9YQ1PFJTAHHyFSZx5_Xy1brh7pHkFYnwFX2bR2Pehb__U_fOdSZc1VY
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL
POSTGRES_DB=babyblog
POSTGRES_USER=babyblog
POSTGRES_PASSWORD=babyblog_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Email (MailHog — тестовая почта)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@babyblog.local

# Медиа-файлы
MEDIA_ROOT=/app/uploads
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=200
MAX_DOCUMENT_SIZE_MB=50

# Безопасность
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://176.53.160.218

# Резервное копирование
BACKUP_DIR=/var/backups/babyblog
